<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Publish to live</title>
  <link rel="stylesheet" href="/assets/main.css">
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">
  <main class="max-w-3xl mx-auto px-6 py-12">
    <header class="flex items-center justify-between gap-4 mb-8">
      <h1 class="text-2xl font-semibold text-slate-900">Publish to live</h1>
      <a href="/" class="editor-badge__link">Back to /</a>
    </header>

    {{if .SetupMode}}
    <section class="rounded-lg border border-amber-200 bg-amber-50 p-6 mb-6" role="status">
      <h2 class="text-lg font-medium text-amber-900 mb-2">Staging setup required</h2>
      <p class="text-slate-700 mb-2">Set <code>productionUrl</code> in <code>workspace/.monms/config.json</code> to your production site URL. New workspaces get this file from <code>monms init</code>; see <code>_fieldDocs</code> in the file for all options.</p>
      <p class="text-slate-600 text-sm">Publishing is disabled until production URL is configured.</p>
    </section>
    {{else}}
    <section class="mb-6" aria-labelledby="publish-status-heading">
      <h2 id="publish-status-heading" class="sr-only">Publish status</h2>
      <p class="text-slate-700 mb-2">
        <span class="font-medium">Last published:</span>
        {{if .LastPublished}}{{.LastPublished}}{{else}}Never{{end}}
      </p>
      <p class="flex items-center gap-2 text-sm">
        <span class="inline-block w-2 h-2 rounded-full {{if .HasChanges}}bg-amber-500{{else}}bg-emerald-500{{end}}" aria-hidden="true"></span>
        <span>{{.StatusLabel}}</span>
      </p>
    </section>

    <section class="mb-8" aria-labelledby="pending-changes-heading">
      <h2 id="pending-changes-heading" class="text-lg font-medium text-slate-900 mb-3">Pending changes</h2>
      {{if .HasChanges}}
      <ul class="space-y-4 list-none p-0 m-0">
        {{range .ChangeGroups}}
        <li class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
          <h3 class="font-medium text-slate-800 mb-2">{{.Collection}}</h3>
          <dl class="space-y-1 text-sm text-slate-600">
            {{range .Fields}}
            <div>
              <dt class="inline font-medium">{{.Field}}:</dt>
              <dd class="inline">{{.Summary}}</dd>
            </div>
            {{end}}
          </dl>
        </li>
        {{end}}
      </ul>
      {{if not .ChangeGroups}}
      <ul class="list-disc pl-5 text-slate-600">
        {{range .Changes}}
        <li>{{.}}</li>
        {{end}}
      </ul>
      {{end}}
      {{else}}
      <p class="text-slate-600">No pending changes — production matches staging editorial content.</p>
      {{end}}
    </section>

    {{if .Message}}
    <div class="rounded-lg border {{if .MessageError}}border-red-200 bg-red-50 text-red-900{{else}}border-emerald-200 bg-emerald-50 text-emerald-900{{end}} p-4 mb-6" role="alert">
      {{.Message}}
    </div>
    {{end}}

    <p class="text-sm text-amber-800 bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4" role="note">
      Publish updates and adds editorial records on production. Deleting content on staging does <strong>not</strong> remove records from production.
    </p>

    <div class="flex flex-wrap items-center gap-4">
      <a href="/_monms/publish/diff" class="editor-badge__link">Preview diff</a>
      <form method="post" action="/_monms/publish" class="inline">
        <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
          Publish now
        </button>
      </form>
    </div>
    {{end}}
  </main>
</body>
</html>
