# Dockerfile.example — thin L1 engine image for git-on-volume deploy.
#
# Build the production binary in the MonMS engine repo, then copy it into this
# workspace before building the image:
#
#   go build -ldflags "-X main.buildMode=production" -o monms /path/to/monms
#   cp monms ./workspace/
#   docker build -f Dockerfile.example -t monms:production .
#
# Do NOT commit the monms binary to Git (see .gitignore).
#
# Runtime layout (see DEPLOY-DOCKER.md):
#   /app/              bind mount — git checkout of this workspace repo (L2)
#   /app/.pb_data/     named volume — PocketBase SQLite (L3, persists)
#   /app/.monms/config.json  secret mount — site-specific config (gitignored)

FROM alpine:3.20

RUN apk add --no-cache ca-certificates git

COPY monms /usr/local/bin/monms
RUN chmod +x /usr/local/bin/monms

WORKDIR /app

# L3 runtime — must be a named volume or host path; never bake into the image.
VOLUME ["/app/.pb_data"]

EXPOSE 8090

ENTRYPOINT ["monms", "serve", "-w", "/app"]
